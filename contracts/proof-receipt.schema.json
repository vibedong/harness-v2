{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-v2://contracts/proof-receipt.schema.json",
  "title": "HARNESS V2 ProofReceipt",
  "type": "object",
  "required": ["kind", "receipt_id", "task_id", "proof_obligation", "proof_obligation_sha256", "verifier", "source_refs"],
  "properties": {
    "kind": { "const": "ProofReceipt" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "proof_obligation": { "type": "string", "minLength": 1 },
    "proof_obligation_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "verifier": {
      "type": "object",
      "required": ["method", "ok", "output_sha256"],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "command": { "type": "string" },
        "command_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "readback": { "type": "string" },
        "ok": { "type": "boolean" },
        "exit_code": { "type": "integer" },
        "output_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": true
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "affects": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": true
      }
    },
    "lifecycle_transition": { "type": "boolean" }
  },
  "additionalProperties": true
}
