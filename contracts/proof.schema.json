{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-v2://contracts/proof.schema.json",
  "title": "HARNESS V2 Proof Obligation",
  "type": "object",
  "required": ["obligations"],
  "properties": {
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
