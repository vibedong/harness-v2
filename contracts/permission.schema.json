{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-v2://contracts/permission.schema.json",
  "title": "HARNESS V2 Permission Scope",
  "type": "object",
  "required": ["allowed_side_effects", "denied_side_effects"],
  "properties": {
    "allowed_side_effects": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "denied_side_effects": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
