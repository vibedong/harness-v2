{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-v2://contracts/approval.schema.json",
  "title": "HARNESS V2 Approval Scope",
  "type": "object",
  "required": ["packet", "approved_paths"],
  "properties": {
    "packet": { "type": "string", "minLength": 1 },
    "approved_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "excluded_side_effects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
