{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-v2://contracts/task.schema.json",
  "title": "HARNESS V2 Task",
  "type": "object",
  "required": ["task_id", "title", "workflow", "workflow_stage", "source", "approval", "permission", "proof", "lifecycle"],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "minLength": 1 },
    "workflow_stage": {
      "type": "string",
      "enum": [
        "spec",
        "spec_review",
        "plan",
        "plan_review",
        "plan_approval",
        "planning",
        "approval",
        "development",
        "development_review",
        "improvement",
        "artifact_observation",
        "routing",
        "safety_improvement",
        "release_boundary"
      ]
    },
    "source": {
      "type": "object",
      "required": ["basis", "current_pointer"],
      "properties": {
        "basis": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "current_pointer": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "approval": { "$ref": "harness-v2://contracts/approval.schema.json" },
    "permission": { "$ref": "harness-v2://contracts/permission.schema.json" },
    "proof": { "$ref": "harness-v2://contracts/proof.schema.json" },
    "lifecycle": { "$ref": "harness-v2://contracts/lifecycle.schema.json" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "harness-v2://contracts/artifact.schema.json" }
    }
  },
  "additionalProperties": true
}
